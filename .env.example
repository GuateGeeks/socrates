# Database
DATABASE_URL="postgresql://socrates:your_password_here@localhost:5432/socrates"
POSTGRES_PASSWORD="your_password_here"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate_with_openssl_rand_base64_32"

# OpenAI
OPENAI_API_KEY="sk-..."

# Shared secret for jarvis-ui → Socrates RAG proxy
# Must match SOCRATES_API_KEY in jarvis-ui/.env.local
SOCRATES_API_KEY="your_shared_secret_here"

# App
NODE_ENV="development"
